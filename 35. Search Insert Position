class Solution:
    def searchInsert(self, nums: List[int], target: int) -> int:
        for i in range(0,len(nums)):
            if target in nums:
                output = nums.index(target)
                return output
        for i in range(0,len(nums)):
            if nums[i] > target :
                return i
                break
        return(len(nums))
                
        

class Solution:
    def isValid(self, s: str) -> bool:
        stack = []
    
        for char in s:
            
            if char == "(" or char == "{" or char == "[":
                stack.append(char)
                
            elif char == ")" or char == "}" or char == "]":

                if not stack:
                    return False
                    
                top = stack[-1]
                
                if (char == ")" and top == "(") or \
                   (char == "}" and top == "{") or \
                   (char == "]" and top == "["):
                    stack.pop()
                else:
                    return False
                    

        return len(stack) == 0

from collections import Counter
class Solution:
    def isGood(self, nums: List[int]) -> bool:
        nums.sort()

        #Find the value of base n
        base = nums[-1]

        #Find the length of base n
        len_nums = len(nums)

        #Condition Check : if length of nums array is n+1
        if(len_nums == base + 1):

            #Condition Check : if the length of array is 2 and if both the elements are same 
            if(len_nums == 2):
                if(nums[0] == base and nums[1] == base):
                    return True
                else:
                    return False

            #Condition Check : if the length of the array is greater than 2, then last 2 elements should be n, 3rd last element should be n-1 and the other elements should be of length exactly one
            if(len_nums > 2):
                freq_map = Counter(nums)
                if nums[-1] != base or nums[-2] != base or nums[-3] != base - 1:
                    return False

                for i in range(1, base):
                    if freq_map[i] != 1:
                        return False

                if freq_map[base] != 2:
                    return False

                return True

        else:
            return False

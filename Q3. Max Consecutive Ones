class Solution:
    def findMaxConsecutiveOnes(self, nums: List[int]) -> int:
        frequency = []
        count = 0 

        for i in range(0,len(nums)):

            if nums[i] == 1:
                count = count + 1 

            if nums[i] == 0:
                frequency.append(count)
                count = 0

        frequency.append(count)

        output = max(frequency)
        return output 


        
